{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and stats.",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "description": "The user's avatar URL."
        },
        "createdAt": {
          "type": "string",
          "description": "ISO timestamp of creation."
        },
        "points": {
          "type": "number"
        },
        "coins": {
          "type": "number"
        },
        "xp": {
          "type": "number"
        },
        "level": {
          "type": "number"
        }
      },
      "required": ["username", "createdAt", "points", "coins", "xp", "level"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    }
  }
}
